{
  "name": "rbac-management-system",
  "version": "1.0.0",
  "description": "RBAC Management System using Bun.js + TypeScript + EJS + TailwindCSS + MySQL2",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build:css": "bunx tailwindcss -i ./src/views/styles.css -o ./public/css/style.css --minify",
    "watch:css": "bunx tailwindcss -i ./src/views/styles.css -o ./public/css/style.css --watch"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "mysql2": "^3.9.8"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.12.12",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5"
  }
}
