<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-950 text-slate-100">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In — SentryRBAC</title>
  <!-- Google Fonts: Outfit & Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <!-- FontAwesome Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <!-- Compiled TailwindCSS -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="h-full font-sans antialiased overflow-y-auto flex items-center justify-center p-4 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-950 via-slate-950 to-black">

  <div class="w-full max-w-md space-y-8 my-8">
    <!-- Header/Logo Section -->
    <div class="text-center space-y-3">
      <div class="inline-flex bg-indigo-600 text-white p-4 rounded-2xl items-center justify-center shadow-2xl shadow-indigo-600/30 ring-4 ring-indigo-500/10">
        <i class="fa-solid fa-shield-halved text-3xl"></i>
      </div>
      <h1 class="text-4xl font-extrabold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-white via-slate-200 to-indigo-400 font-outfit">
        SentryRBAC
      </h1>
      <p class="text-slate-400 text-sm font-medium">Role-Based Access Control Management System</p>
    </div>

    <!-- Main Login Card -->
    <div class="bg-slate-900/60 backdrop-blur-xl border border-slate-800 rounded-3xl p-8 shadow-2xl shadow-black/80 space-y-6">
      
      <!-- Notifications -->
      <% if (locals.error) { %>
        <div class="bg-red-500/10 border border-red-500/20 text-red-400 text-xs rounded-xl p-4 flex items-start space-x-3">
          <i class="fa-solid fa-circle-exclamation text-base mt-0.5"></i>
          <div>
            <span class="font-bold">Access Denied:</span>
            <p class="mt-0.5"><%= error %></p>
          </div>
        </div>
      <% } %>

      <% if (locals.success) { %>
        <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs rounded-xl p-4 flex items-start space-x-3">
          <i class="fa-solid fa-circle-check text-base mt-0.5"></i>
          <div>
            <span class="font-bold">Success:</span>
            <p class="mt-0.5"><%= success %></p>
          </div>
        </div>
      <% } %>

      <!-- Login Form -->
      <form action="/login" method="POST" class="space-y-5">
        
        <!-- Username input -->
        <div class="space-y-2">
          <label for="username" class="text-xs font-bold uppercase tracking-wider text-slate-400">Username</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-500">
              <i class="fa-solid fa-user"></i>
            </span>
            <input type="text" id="username" name="username" required placeholder="Enter username..."
              class="w-full bg-slate-950/80 border border-slate-800 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 rounded-xl pl-10 pr-4 py-3 text-sm text-slate-200 placeholder-slate-600 outline-none transition-all duration-200">
          </div>
        </div>

        <!-- Password input -->
        <div class="space-y-2">
          <div class="flex justify-between items-center">
            <label for="password" class="text-xs font-bold uppercase tracking-wider text-slate-400">Password</label>
          </div>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-500">
              <i class="fa-solid fa-lock"></i>
            </span>
            <input type="password" id="password" name="password" required placeholder="••••••••"
              class="w-full bg-slate-950/80 border border-slate-800 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 rounded-xl pl-10 pr-4 py-3 text-sm text-slate-200 placeholder-slate-600 outline-none transition-all duration-200">
          </div>
        </div>

        <!-- Submit Button -->
        <button type="submit"
          class="w-full bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-500 hover:to-violet-500 text-white font-bold py-3 px-4 rounded-xl shadow-lg shadow-indigo-600/20 hover:shadow-indigo-600/30 transition-all duration-200 flex items-center justify-center space-x-2 text-sm">
          <span>Authenticate Session</span>
          <i class="fa-solid fa-arrow-right-to-bracket text-xs"></i>
        </button>
      </form>

      <!-- Testing Accounts Section -->
      <div class="pt-6 border-t border-slate-800/80 space-y-3">
        <span class="text-xs font-bold uppercase tracking-wider text-slate-400 block"><i class="fa-solid fa-circle-info mr-1 text-indigo-400"></i> Seeded Accounts</span>
        <div class="grid grid-cols-1 gap-2 text-xs">
          <!-- Admin account -->
          <div onclick="document.getElementById('username').value='admin'; document.getElementById('password').value='admin123';"
               class="bg-indigo-500/5 hover:bg-indigo-500/10 border border-indigo-500/10 hover:border-indigo-500/30 rounded-xl p-2.5 flex items-center justify-between cursor-pointer transition">
            <div>
              <span class="font-bold text-slate-200">admin</span>
              <span class="text-[10px] text-slate-500 block">Password: admin123</span>
            </div>
            <span class="px-2 py-0.5 bg-indigo-500/10 text-indigo-400 text-[10px] font-bold uppercase rounded-md tracking-wider border border-indigo-500/10">Admin (All Access)</span>
          </div>

          <!-- Editor account -->
          <div onclick="document.getElementById('username').value='editor'; document.getElementById('password').value='editor123';"
               class="bg-cyan-500/5 hover:bg-cyan-500/10 border border-cyan-500/10 hover:border-cyan-500/30 rounded-xl p-2.5 flex items-center justify-between cursor-pointer transition">
            <div>
              <span class="font-bold text-slate-200">editor</span>
              <span class="text-[10px] text-slate-500 block">Password: editor123</span>
            </div>
            <span class="px-2 py-0.5 bg-cyan-500/10 text-cyan-400 text-[10px] font-bold uppercase rounded-md tracking-wider border border-cyan-500/10">Editor (View/Create)</span>
          </div>

          <!-- Viewer account -->
          <div onclick="document.getElementById('username').value='viewer'; document.getElementById('password').value='viewer123';"
               class="bg-emerald-500/5 hover:bg-emerald-500/10 border border-emerald-500/10 hover:border-emerald-500/30 rounded-xl p-2.5 flex items-center justify-between cursor-pointer transition">
            <div>
              <span class="font-bold text-slate-200">viewer</span>
              <span class="text-[10px] text-slate-500 block">Password: viewer123</span>
            </div>
            <span class="px-2 py-0.5 bg-emerald-500/10 text-emerald-400 text-[10px] font-bold uppercase rounded-md tracking-wider border border-emerald-500/10">Viewer (View Only)</span>
          </div>
        </div>
      </div>

    </div>
  </div>

</body>
</html>
